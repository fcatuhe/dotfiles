#!/usr/bin/env bash
# Edit encrypted secrets. Re-encrypts on save.
# Copy this file to the root of your dotfiles repository.
set -euo pipefail

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SECRETS="$BASEDIR/encrypted/secrets.env.age"
IDENTITY="$BASEDIR/encrypted/age.key"

[[ -f "$IDENTITY" ]] || { echo "ERROR: age identity not found at $IDENTITY"; exit 1; }
[[ -f "$SECRETS" ]] || { echo "ERROR: encrypted secrets not found at $SECRETS"; exit 1; }

# Derive recipient (public key) from the private key
RECIPIENT="$(age-keygen -y "$IDENTITY")"

tmpfile="$(mktemp)"
trap 'rm -f "$tmpfile"' EXIT

age -d -i "$IDENTITY" "$SECRETS" > "$tmpfile"
checksum_before="$(shasum -a 256 "$tmpfile")"

${EDITOR:-vim} "$tmpfile"

if [[ "$(shasum -a 256 "$tmpfile")" == "$checksum_before" ]]; then
  echo "No changes made."
  exit 0
fi

age -r "$RECIPIENT" "$tmpfile" > "$SECRETS"
echo "Secrets re-encrypted. Run ./install to update private/."
