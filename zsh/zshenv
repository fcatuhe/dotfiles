# Bitwarden SSH agent (macOS)
_bw_sock="$HOME/Library/Containers/com.bitwarden.desktop/Data/.bitwarden-ssh-agent.sock"
[ -S "$_bw_sock" ] && export SSH_AUTH_SOCK="$_bw_sock"
unset _bw_sock

# QMD: workaround llama.cpp Metal teardown crash on macOS 15+ (ggml-org/llama.cpp#22593)
export GGML_METAL_NO_RESIDENCY=1

[ -f ~/.zshenv.private ] && source ~/.zshenv.private
