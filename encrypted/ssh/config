Host patoumatic dropbear-patoumatic
  HostName {{SSH_PATOUMATIC_IP}}
  User {{SSH_PATOUMATIC_USER}}

Host dropbear-patoumatic
  Port 2222

Host crooz
  HostName {{SSH_CROOZ_IP}}
  User {{SSH_CROOZ_USER}}

Host azade
  HostName {{SSH_AZADE_IP}}
  User {{SSH_AZADE_USER}}

Host *
  IgnoreUnknown UseKeychain
  UseKeychain yes
  AddKeysToAgent yes
  IdentityAgent ~/.bitwarden-ssh-agent.sock
  SetEnv TERM=xterm-256color

Match host * exec "uname | grep -q Darwin"
  IdentityFile ~/.ssh/id_ed25519
  Include ~/.colima/ssh_config
