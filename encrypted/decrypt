#!/usr/bin/env bash
# Decrypt private.env.age and render encrypted source files into private/.
set -euo pipefail

ENCRYPTED_DIR="$(cd "$(dirname "$0")" && pwd)"
DOTFILES_DIR="$(dirname "$ENCRYPTED_DIR")"
PRIVATE_DIR="$DOTFILES_DIR/private"

# Read age.conf
conf_val() { grep "^${1}=" "$ENCRYPTED_DIR/age.conf" | head -1 | cut -d= -f2-; }

IDENTITY="$ENCRYPTED_DIR/$(conf_val identity)"
PRIVATE_FILE="$ENCRYPTED_DIR/$(conf_val private)"

[[ -f "$IDENTITY" ]]    || { echo "ERROR: age identity not found at $IDENTITY"; exit 1; }
[[ -f "$PRIVATE_FILE" ]] || { echo "ERROR: $PRIVATE_FILE not found"; exit 1; }

decrypted="$(age -d -i "$IDENTITY" "$PRIVATE_FILE")"

# Find all source files in encrypted/ (skip age.conf, age.key, *.age, scripts)
for src in "$ENCRYPTED_DIR"/*/*.* "$ENCRYPTED_DIR"/*/*; do
  [[ -f "$src" ]] || continue

  content="$(cat "$src")"
  while IFS='=' read -r key value; do
    [[ -z "$key" || "$key" =~ ^# ]] && continue
    content="${content//\{\{${key}\}\}/${value}}"
  done <<< "$decrypted"

  # Mirror path: encrypted/ssh/config → private/ssh/config
  relative="${src#$ENCRYPTED_DIR/}"
  dest="$PRIVATE_DIR/$relative"

  mkdir -p "$(dirname "$dest")"
  printf '%s\n' "$content" > "$dest"
  echo "  → $dest"
done

find "$PRIVATE_DIR" -type d -exec chmod 700 {} \;
find "$PRIVATE_DIR" -type f -exec chmod 600 {} \;
