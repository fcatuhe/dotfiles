{
  // Editor
  "editor.accessibilitySupport": "off",
  "editor.fontFamily": "'Cascadia Code', 'JetBrains Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 13,
  "editor.formatOnSave": true,
  "editor.rulers": [120],
  "editor.tabSize": 2,
  "diffEditor.ignoreTrimWhitespace": false,

  // Files
  "files.autoSave": "onFocusChange",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,
  "files.associations": {
    "*.html.erb": "erb",
    "llms.txt": "markdown",
    "llms-full.txt": "markdown"
  },

  // Explorer
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.sortOrder": "mixed",

  // Workbench
  "workbench.colorTheme": "Spinel",
  "workbench.sideBar.location": "right",
  "update.showReleaseNotes": false,

  // Git
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.detectSubmodules": false,
  "git.autoRepositoryDetection": "openEditors",

  // Formatters
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.requireConfig": true,
  "[erb]": {
    "editor.defaultFormatter": "Shopify.ruby-lsp"
  },
  "[ruby]": {
    "editor.defaultFormatter": "Shopify.ruby-lsp",
    "editor.formatOnType": true,
    "editor.semanticHighlighting.enabled": true,
    "files.trimFinalNewlines": true
  },
  "[sql]": {
    "editor.defaultFormatter": "inferrinizzard.prettier-sql-vscode"
  },
  "[dockercompose]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },

  // Extensions
  "extensions.ignoreRecommendations": false,
  "rubyLsp.enableExperimentalFeatures": false,
  "github.copilot.editor.enableAutoCompletions": true,
  "claudeCode.selectedModel": "default",
  "claudeCode.allowDangerouslySkipPermissions": true,
  "claudeCode.preferredLocation": "sidebar",

  // Privacy
  "telemetry.telemetryLevel": "off",
  "redhat.telemetry.enabled": false,
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.startupEditor": "none"
}
